#!/usr/bin/env bash
# KB session capture hook — Stop event
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "${SCRIPT_DIR}/.." && pwd)}"
VAULT_PATH="${KB_VAULT:-${HOME}/kb}"

if command -v bun >/dev/null 2>&1; then
  BUN_BIN="bun"
elif [ -x "${HOME}/.bun/bin/bun" ]; then
  BUN_BIN="${HOME}/.bun/bin/bun"
else
  mkdir -p "${VAULT_PATH}/.kb"
  printf '{"ts":"%s","stage":"bash","reason":"bun-not-found"}\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" >> "${VAULT_PATH}/.kb/capture-errors.log"
  exit 0
fi

"${BUN_BIN}" "${PLUGIN_ROOT}/src/cli.ts" capture-session || true
exit 0
