{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "KB trust boundary — best-effort deny rules for untrusted vault surfaces. Sanctioned access goes through `kb recall/get/list-topics` (curated) and `kb read-raw/read-session` (ask-gated). Bash denies enumerate common readers; the R2a self-test (hooks/security-self-test) is the regression detector for the overall boundary.",
  "permissions": {
    "deny": [
      "Read(**/kb/raw/**)",
      "Read(**/kb/sessions/**)",
      "Read(**/kb/.kb/*.jsonl)",
      "Read(**/kb/.kb/*.jsonl.1)",
      "Read(~/kb/raw/**)",
      "Read(~/kb/sessions/**)",
      "Read(~/kb/.kb/*.jsonl)",
      "Read(~/kb/.kb/*.jsonl.1)",

      "Grep(**/kb/raw/**)",
      "Grep(**/kb/sessions/**)",
      "Grep(**/kb/.kb/**)",
      "Grep(~/kb/raw/**)",
      "Grep(~/kb/sessions/**)",
      "Grep(~/kb/.kb/**)",

      "Glob(**/kb/raw/**)",
      "Glob(**/kb/sessions/**)",
      "Glob(**/kb/.kb/**)",
      "Glob(~/kb/raw/**)",
      "Glob(~/kb/sessions/**)",
      "Glob(~/kb/.kb/**)",

      "Bash(cat* *kb/raw/*)",
      "Bash(cat* *kb/sessions/*)",
      "Bash(cat* *kb/.kb/*.jsonl*)",
      "Bash(head* *kb/raw/*)",
      "Bash(head* *kb/sessions/*)",
      "Bash(head* *kb/.kb/*.jsonl*)",
      "Bash(tail* *kb/raw/*)",
      "Bash(tail* *kb/sessions/*)",
      "Bash(tail* *kb/.kb/*.jsonl*)",
      "Bash(less* *kb/raw/*)",
      "Bash(less* *kb/sessions/*)",
      "Bash(less* *kb/.kb/*.jsonl*)",
      "Bash(more* *kb/raw/*)",
      "Bash(more* *kb/sessions/*)",
      "Bash(more* *kb/.kb/*.jsonl*)",
      "Bash(grep* *kb/raw/*)",
      "Bash(grep* *kb/sessions/*)",
      "Bash(grep* *kb/.kb/*.jsonl*)",
      "Bash(rg* *kb/raw/*)",
      "Bash(rg* *kb/sessions/*)",
      "Bash(rg* *kb/.kb/*.jsonl*)",
      "Bash(awk* *kb/raw/*)",
      "Bash(awk* *kb/sessions/*)",
      "Bash(awk* *kb/.kb/*.jsonl*)",
      "Bash(sed* *kb/raw/*)",
      "Bash(sed* *kb/sessions/*)",
      "Bash(sed* *kb/.kb/*.jsonl*)",
      "Bash(cut* *kb/raw/*)",
      "Bash(cut* *kb/sessions/*)",
      "Bash(cut* *kb/.kb/*.jsonl*)",
      "Bash(xxd* *kb/raw/*)",
      "Bash(xxd* *kb/sessions/*)",
      "Bash(xxd* *kb/.kb/*.jsonl*)",
      "Bash(od* *kb/raw/*)",
      "Bash(od* *kb/sessions/*)",
      "Bash(od* *kb/.kb/*.jsonl*)",
      "Bash(strings* *kb/raw/*)",
      "Bash(strings* *kb/sessions/*)",
      "Bash(strings* *kb/.kb/*.jsonl*)",
      "Bash(bat* *kb/raw/*)",
      "Bash(bat* *kb/sessions/*)",
      "Bash(bat* *kb/.kb/*.jsonl*)",
      "Bash(python* *kb/raw/*)",
      "Bash(python* *kb/sessions/*)",
      "Bash(python* *kb/.kb/*.jsonl*)",
      "Bash(python3* *kb/raw/*)",
      "Bash(python3* *kb/sessions/*)",
      "Bash(python3* *kb/.kb/*.jsonl*)",
      "Bash(ruby* *kb/raw/*)",
      "Bash(ruby* *kb/sessions/*)",
      "Bash(ruby* *kb/.kb/*.jsonl*)",
      "Bash(node* *kb/raw/*)",
      "Bash(node* *kb/sessions/*)",
      "Bash(node* *kb/.kb/*.jsonl*)",
      "Bash(bun* *kb/raw/*)",
      "Bash(bun* *kb/sessions/*)",
      "Bash(bun* *kb/.kb/*.jsonl*)"
    ]
  }
}
